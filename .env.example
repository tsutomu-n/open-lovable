# =================================================================
# REQUIRED FOR WEBSITE CLONING
# =================================================================
FIRECRAWL_API_KEY=your_firecrawl_api_key

# =================================================================
# FASTEST LOCAL AI SETUP
# =================================================================
GEMINI_API_KEY=your_gemini_api_key

# =================================================================
# SANDBOX PROVIDER - RECOMMENDED FOR LOCAL
# =================================================================
# If omitted, the app auto-selects E2B first, then Vercel when credentials exist.
SANDBOX_PROVIDER=e2b
E2B_API_KEY=your_e2b_api_key

# =================================================================
# OPTIONAL - AI GATEWAY INSTEAD OF DIRECT PROVIDER KEYS
# =================================================================
# AI_GATEWAY_API_KEY=your_ai_gateway_api_key

# =================================================================
# OPTIONAL - OTHER DIRECT PROVIDERS
# =================================================================
# ANTHROPIC_API_KEY=your_anthropic_api_key
# OPENAI_API_KEY=your_openai_api_key
# GROQ_API_KEY=your_groq_api_key

# =================================================================
# OPTIONAL - VERCEL SANDBOX INSTEAD OF E2B
# =================================================================
# SANDBOX_PROVIDER=vercel
# VERCEL_OIDC_TOKEN=auto_generated_by_vercel_env_pull
# VERCEL_TEAM_ID=your_team_id
# VERCEL_PROJECT_ID=your_project_id
# VERCEL_TOKEN=your_access_token

# =================================================================
# OPTIONAL - FAST APPLY
# =================================================================
# MORPH_API_KEY=your_morphllm_api_key
